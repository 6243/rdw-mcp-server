{
  "name": "rdw-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Dutch RDW (Rijksdienst voor het Wegverkeer) open vehicle data",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rdw-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "PORT=8000 node dist/index.js --http",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.8.0",
    "express": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
